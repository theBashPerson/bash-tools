#!/bin/bash
# fkill — fuzzy kill. pick your victim.
command -v fzf &>/dev/null || { echo -e "\e[1;31m󰅚 fzf required\e[0m"; exit 1; }

selected=$(ps aux --no-headers | grep -v "^$USER.*fkill\|^$USER.*grep" | \
    fzf --prompt="󱕅 select process to obliterate: " \
        --height=40% \
        --layout=reverse \
        --border \
        --header="  PID  | USER     | CPU | MEM | COMMAND" \
        --preview="echo {} | awk '{print \$2}' | xargs -I{} ps -p {} -o pid,ppid,user,stat,start,time,command --no-headers 2>/dev/null" \
        --preview-window=down:4:wrap)

[[ -z "$selected" ]] && { echo -e "\e[1;33m󰜺 nothing selected. aborting.\e[0m"; exit 0; }

pid=$(echo "$selected" | awk '{print $2}')
proc=$(echo "$selected" | awk '{print $11}')

echo -e "\e[1;31m󱕅 targeting: \e[1;37m$proc \e[1;31m(PID: $pid)\e[0m"
read -rp "$(echo -e "\e[1;33msignal? [9/15/2] (default: 9): \e[0m")" sig
sig=${sig:-9}

kill -"$sig" "$pid" 2>/dev/null && \
    echo -e "\e[1;32m󰆴 process $pid terminated with signal $sig\e[0m" || \
    echo -e "\e[1;31m󰅚 failed to kill $pid (permission denied?)\e[0m"
