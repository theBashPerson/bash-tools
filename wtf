#!/bin/bash
# wtf — what is that command actually
if [[ -z "$1" ]]; then
    echo -e "\e[1;31m󰅚 usage: wtf <command>\e[0m"
    exit 1
fi

cmd="$1"
echo -e "\e[1;36m󰋖 investigating: \e[1;37m$cmd\e[0m\n"

# type: builtin / alias / function / file
type_info=$(type -a "$cmd" 2>/dev/null)
if [[ -z "$type_info" ]]; then
    echo -e "\e[1;31m󰅚 '$cmd' not found anywhere on your PATH\e[0m"
    exit 1
fi

echo -e "\e[1;33m󰁊 type info:\e[0m"
echo "$type_info" | sed 's/^/  /'

# binary location
bin_path=$(command -v "$cmd" 2>/dev/null)
if [[ -n "$bin_path" ]]; then
    echo -e "\n\e[1;33m󰙅 binary:\e[0m"
    echo "  $bin_path"

    # package owner (pacman)
    if command -v pacman &>/dev/null; then
        pkg=$(pacman -Qo "$bin_path" 2>/dev/null | awk '{print $5, $6}')
        if [[ -n "$pkg" ]]; then
            echo -e "\n\e[1;33m󰮯 package:\e[0m"
            echo "  $pkg"
        fi
    fi
fi

# man page one-liner
if command -v man &>/dev/null && man -w "$cmd" &>/dev/null; then
    echo -e "\n\e[1;33m󰂺 man summary:\e[0m"
    man "$cmd" 2>/dev/null | col -bx | awk '
        /^NAME/{ found=1; next }
        found && /^[A-Z]/ && !/^NAME/{ exit }
        found{ print "  " $0 }
    ' | head -n 5
fi
