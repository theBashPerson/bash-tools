#!/bin/bash
# hgrep — grep but it looks good
if [[ -z "$1" ]]; then
    echo -e "\e[1;31m󰅚 usage: hgrep <pattern> [file/dir] [extra grep flags]\e[0m"
    exit 1
fi

pattern="$1"
shift
target="${1:-.}"
shift

echo -e "\e[1;36m󰍉 hunting for: \e[1;33m$pattern\e[1;36m in \e[1;37m$target\e[0m\n"

grep_output=$(grep -rn --color=always -C2 "$@" "$pattern" "$target" 2>/dev/null)

if [[ -z "$grep_output" ]]; then
    echo -e "\e[1;31m󰅚 no matches found\e[0m"
    exit 1
fi

echo "$grep_output" | while IFS= read -r line; do
    # highlight file:line headers differently
    if echo "$line" | grep -qP '^\e\[.*\d+[-:]'; then
        echo -e "\e[1;35m$line\e[0m"
    else
        echo "$line"
    fi
done

match_count=$(echo "$grep_output" | grep -c "^" 2>/dev/null || echo "?")
echo -e "\n\e[1;36m󰄬 done. \e[1;37m$match_count line(s)\e[1;36m returned.\e[0m"
