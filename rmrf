#!/bin/bash
# rmrf — interactive recursive delete. think before you yeet.
command -v fzf &>/dev/null || { echo -e "\e[1;31m󰅚 fzf required\e[0m"; exit 1; }

if [[ -z "$1" ]]; then
    echo -e "\e[1;31m󰅚 usage: rmrf <path>\e[0m"
    exit 1
fi

target="$1"

if [[ ! -e "$target" ]]; then
    echo -e "\e[1;31m󰅚 '$target' does not exist\e[0m"
    exit 1
fi

# show what's inside if it's a directory
echo -e "\e[1;33m  preview of what you're about to obliterate:\e[0m\n"
if [[ -d "$target" ]]; then
    find "$target" | head -n 40 | sed 's/^/  /'
    count=$(find "$target" | wc -l)
    echo -e "\n  \e[1;37m... $count item(s) total\e[0m"
else
    ls -lh "$target" | sed 's/^/  /'
fi

echo ""
read -rp "$(echo -e "\e[1;31m  are you absolutely sure? type 'DELETE' to confirm: \e[0m")" confirm

if [[ "$confirm" == "DELETE" ]]; then
    rm -rf "$target"
    echo -e "\e[1;32m󰆴 obliterated: \e[1;37m$target\e[0m"
else
    echo -e "\e[1;33m󰜺 cancelled. \e[1;37m$target\e[1;33m still exists.\e[0m"
fi
